                min-height: 22px;
            }
            QProgressBar::chunk {
                background: #22c55e;
                border-radius: 8px;
            }
        """)

        self.timer = QTimer(self)
        self.timer.timeout.connect(self.refresh)
        self.timer.start(30_000)

        self.refresh()

    def get_state(self):
        start = read_int(START_FILE)
        stop = read_int(STOP_FILE)
        capacity = read_int(CAPACITY_FILE)
        status = read_text(STATUS_FILE)
        manufacturer = read_text(MANUFACTURER_FILE, "")
        model = read_text(MODEL_FILE, "")
        return start, stop, capacity, status, manufacturer, model

    def refresh(self):
        start, stop, capacity, status, manufacturer, model = self.get_state()

        if capacity >= 0:
            self.capacity_bar.setValue(capacity)
            self.capacity_bar.setFormat(f"{capacity}%")
        else:
            self.capacity_bar.setValue(0)
            self.capacity_bar.setFormat("Unknown")

        mode = mode_name(start, stop)
        self.mode_label.setText(mode)
        self.status_label.setText(status)
        self.start_label.setText(f"{start}%")
        self.stop_label.setText(f"{stop}%")
        self.device_label.setText(" ".join(x for x in [manufacturer, model] if x).strip() or "BAT0")

        self.custom_start.setValue(start if 0 <= start <= 100 else 70)
        self.custom_stop.setValue(stop if 0 <= stop <= 100 else 80)

        self.tray.update_tooltip(mode, start, stop, capacity, status)

    def apply_mode(self, mode: str):
        result = run_pkexec([mode])
        if result.returncode != 0:
            self.show_error("Could not change battery mode", result.stderr or result.stdout)
            return
        self.refresh()

    def apply_custom(self):
        start = self.custom_start.value()
        stop = self.custom_stop.value()

        if start > stop:
            self.show_error("Invalid thresholds", "Start threshold must be lower than or equal to stop threshold.")
            return

        result = run_pkexec(["set", str(start), str(stop)])
        if result.returncode != 0:
            self.show_error("Could not apply custom thresholds", result.stderr or result.stdout)
            return
        self.refresh()

    def show_error(self, title: str, message: str):
        QMessageBox.critical(self, title, message.strip() or "Unknown error")


class BatteryTray:
    def __init__(self, app: QApplication):
        self.app = app
        self.window = None

        icon = QIcon(str(ICON_PATH))
        if icon.isNull():
            icon = QIcon.fromTheme("battery-good-symbolic")

        self.tray = QSystemTrayIcon(icon)
        self.tray.setToolTip("ThinkPad Battery")

        self.menu = QMenu()

        self.summary_action = QAction("ThinkPad Battery")
        self.summary_action.setEnabled(False)

        self.mode_action = QAction("Mode: Unknown")
        self.mode_action.setEnabled(False)

        self.battery_action = QAction("Battery: Unknown")
        self.battery_action.setEnabled(False)

        self.threshold_action = QAction("Thresholds: Unknown")
        self.threshold_action.setEnabled(False)

        self.open_action = QAction("Open Battery Control")
        self.open_action.triggered.connect(self.show_window)

        self.conserve_action = QAction("Set Conservation 70/80")
        self.conserve_action.triggered.connect(lambda: self.quick_mode("conserve"))

        self.balanced_action = QAction("Set Balanced 80/90")
        self.balanced_action.triggered.connect(lambda: self.quick_custom(80, 90))

        self.full_action = QAction("Set Full until reboot 95/100")
        self.full_action.triggered.connect(lambda: self.quick_mode("full"))

        self.refresh_action = QAction("Refresh")
        self.refresh_action.triggered.connect(self.refresh)

        self.quit_action = QAction("Quit")
        self.quit_action.triggered.connect(self.app.quit)

        self.menu.addAction(self.summary_action)
        self.menu.addAction(self.mode_action)
        self.menu.addAction(self.battery_action)
        self.menu.addAction(self.threshold_action)
        self.menu.addSeparator()
        self.menu.addAction(self.open_action)
        self.menu.addSeparator()
        self.menu.addAction(self.conserve_action)
        self.menu.addAction(self.balanced_action)
        self.menu.addAction(self.full_action)
        self.menu.addSeparator()
        self.menu.addAction(self.refresh_action)
        self.menu.addAction(self.quit_action)

        self.tray.setContextMenu(self.menu)
        self.tray.activated.connect(self.on_activated)
        self.tray.show()

        self.timer = QTimer()
        self.timer.timeout.connect(self.refresh)
        self.timer.start(30_000)

        self.refresh()

    def ensure_window(self):
        if self.window is None:
            self.window = BatteryWindow(self)
        return self.window

    def show_window(self):
        window = self.ensure_window()
        window.refresh()
        window.show()
        window.raise_()
        window.activateWindow()

    def on_activated(self, reason):
        if reason in (QSystemTrayIcon.Trigger, QSystemTrayIcon.DoubleClick):
            self.show_window()

    def quick_mode(self, mode: str):
        result = run_pkexec([mode])
        if result.returncode != 0:
            QMessageBox.critical(None, "Could not change battery mode", (result.stderr or result.stdout).strip())
        self.refresh()
        if self.window:
            self.window.refresh()

    def quick_custom(self, start: int, stop: int):
        result = run_pkexec(["set", str(start), str(stop)])
        if result.returncode != 0:
            QMessageBox.critical(None, "Could not change battery thresholds", (result.stderr or result.stdout).strip())
        self.refresh()
        if self.window:
            self.window.refresh()

    def refresh(self):
        start = read_int(START_FILE)
        stop = read_int(STOP_FILE)
        capacity = read_int(CAPACITY_FILE)
        status = read_text(STATUS_FILE)
        mode = mode_name(start, stop)
        self.update_tooltip(mode, start, stop, capacity, status)

    def update_tooltip(self, mode: str, start: int, stop: int, capacity: int, status: str):
        tooltip = (
            f"ThinkPad Battery\n"
            f"Mode: {mode}\n"
            f"Battery: {capacity}% ({status})\n"
            f"Thresholds: {start}/{stop}"
        )
        self.tray.setToolTip(tooltip)

        if hasattr(self, "mode_action"):
            self.mode_action.setText(f"Mode: {mode}")
            self.battery_action.setText(f"Battery: {capacity}% ({status})")
            self.threshold_action.setText(f"Thresholds: {start} / {stop}")


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("ThinkPad Battery Tray")
    app.setQuitOnLastWindowClosed(False)

    if not QSystemTrayIcon.isSystemTrayAvailable():
        QMessageBox.critical(None, "System tray unavailable", "No system tray is available in this session.")
        return 1

    tray = BatteryTray(app)
    app._thinkpad_battery_tray = tray
    return app.exec()


if __name__ == "__main__":
    raise SystemExit(main())
