#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

from PySide6.QtCore import Qt, QTimer
from PySide6.QtGui import QAction, QIcon
from PySide6.QtWidgets import (
    QApplication,
    QFrame,
    QGridLayout,
    QHBoxLayout,
    QLabel,
    QMainWindow,
    QMenu,
    QMessageBox,
    QPushButton,
    QProgressBar,
    QSpinBox,
    QSystemTrayIcon,
    QVBoxLayout,
    QWidget,
)

APP_DIR = Path("/usr/local/share/thinkpad-battery-tray")
ICON_PATH = APP_DIR / "icon.svg"
HELPER = "/usr/local/libexec/thinkpad-battery-threshold-helper"

BAT_PATH = Path(os.environ.get("THINKPAD_BAT_PATH", "/sys/class/power_supply/BAT0"))
START_FILE = BAT_PATH / "charge_control_start_threshold"
STOP_FILE = BAT_PATH / "charge_control_end_threshold"
CAPACITY_FILE = BAT_PATH / "capacity"
STATUS_FILE = BAT_PATH / "status"
MANUFACTURER_FILE = BAT_PATH / "manufacturer"
MODEL_FILE = BAT_PATH / "model_name"

CONSERVE = (70, 80)
FULL = (95, 100)


def read_text(path: Path, fallback: str = "Unknown") -> str:
    try:
        return path.read_text(encoding="utf-8").strip()
    except Exception:
        return fallback


def read_int(path: Path, fallback: int = -1) -> int:
    try:
        return int(read_text(path, str(fallback)))
    except Exception:
        return fallback


def run_pkexec(args):
    cmd = ["pkexec", HELPER] + args
    return subprocess.run(cmd, text=True, capture_output=True, check=False)


def mode_name(start: int, stop: int) -> str:
    if (start, stop) == CONSERVE:
        return "Conservation"
    if (start, stop) == FULL:
        return "Full charge"
    return "Custom"


class BatteryWindow(QMainWindow):
    def __init__(self, tray):
        super().__init__()
        self.tray = tray
        self.setWindowTitle("ThinkPad Battery")
        self.setMinimumWidth(420)

        root = QWidget()
        self.setCentralWidget(root)

        layout = QVBoxLayout(root)
        layout.setContentsMargins(18, 18, 18, 18)
        layout.setSpacing(14)

        title = QLabel("Lenovo Battery Control")
        title.setObjectName("Title")
        subtitle = QLabel("Charge thresholds for battery health")
        subtitle.setObjectName("Subtitle")

        layout.addWidget(title)
        layout.addWidget(subtitle)

        self.card = QFrame()
        self.card.setObjectName("Card")
        grid = QGridLayout(self.card)
        grid.setContentsMargins(16, 16, 16, 16)
        grid.setHorizontalSpacing(14)
        grid.setVerticalSpacing(10)

        self.mode_label = QLabel("Unknown")
        self.mode_label.setObjectName("Mode")
        self.capacity_bar = QProgressBar()
        self.capacity_bar.setRange(0, 100)
        self.capacity_bar.setTextVisible(True)

        self.status_label = QLabel("Unknown")
        self.start_label = QLabel("Unknown")
        self.stop_label = QLabel("Unknown")
        self.device_label = QLabel("Unknown")

        grid.addWidget(QLabel("Mode"), 0, 0)
        grid.addWidget(self.mode_label, 0, 1)

        grid.addWidget(QLabel("Battery"), 1, 0)
        grid.addWidget(self.capacity_bar, 1, 1)

        grid.addWidget(QLabel("Status"), 2, 0)
        grid.addWidget(self.status_label, 2, 1)

        grid.addWidget(QLabel("Start"), 3, 0)
        grid.addWidget(self.start_label, 3, 1)

        grid.addWidget(QLabel("Stop"), 4, 0)
        grid.addWidget(self.stop_label, 4, 1)

        grid.addWidget(QLabel("Device"), 5, 0)
        grid.addWidget(self.device_label, 5, 1)

        layout.addWidget(self.card)

        button_row = QHBoxLayout()
        self.conserve_button = QPushButton("Conservation 70/80")
        self.full_button = QPushButton("Full until reboot 95/100")
        self.refresh_button = QPushButton("Refresh")

        self.conserve_button.clicked.connect(lambda: self.apply_mode("conserve"))
        self.full_button.clicked.connect(lambda: self.apply_mode("full"))
        self.refresh_button.clicked.connect(self.refresh)

        button_row.addWidget(self.conserve_button)
        button_row.addWidget(self.full_button)
        button_row.addWidget(self.refresh_button)

        layout.addLayout(button_row)

        custom_card = QFrame()
        custom_card.setObjectName("Card")
        custom_layout = QGridLayout(custom_card)
        custom_layout.setContentsMargins(16, 16, 16, 16)
        custom_layout.setHorizontalSpacing(14)
        custom_layout.setVerticalSpacing(10)

        self.custom_start = QSpinBox()
        self.custom_start.setRange(0, 100)
        self.custom_start.setValue(70)
        self.custom_start.setSuffix("%")

        self.custom_stop = QSpinBox()
        self.custom_stop.setRange(0, 100)
        self.custom_stop.setValue(80)
        self.custom_stop.setSuffix("%")

        self.custom_apply = QPushButton("Apply custom")
        self.custom_apply.clicked.connect(self.apply_custom)

        custom_layout.addWidget(QLabel("Custom start"), 0, 0)
        custom_layout.addWidget(self.custom_start, 0, 1)
        custom_layout.addWidget(QLabel("Custom stop"), 1, 0)
        custom_layout.addWidget(self.custom_stop, 1, 1)
        custom_layout.addWidget(self.custom_apply, 2, 0, 1, 2)

        layout.addWidget(custom_card)

        note = QLabel("Full charge mode is temporary. On next boot, the systemd service restores conservation mode.")
        note.setWordWrap(True)
        note.setObjectName("Note")
        layout.addWidget(note)

        self.setStyleSheet("""
            QMainWindow {
                background: #111827;
            }
            QLabel {
                color: #e5e7eb;
                font-size: 13px;
            }
            QLabel#Title {
                font-size: 22px;
                font-weight: 700;
                color: #f9fafb;
            }
            QLabel#Subtitle {
                color: #9ca3af;
                font-size: 13px;
            }
            QLabel#Mode {
                font-size: 18px;
                font-weight: 700;
                color: #86efac;
            }
            QLabel#Note {
                color: #9ca3af;
            }
            QFrame#Card {
                background: #1f2937;
                border: 1px solid #374151;
                border-radius: 14px;
            }
            QPushButton {
                background: #2563eb;
                color: white;
                border: none;
                border-radius: 10px;
                padding: 9px 12px;
                font-weight: 600;
            }
            QPushButton:hover {
                background: #1d4ed8;
            }
            QSpinBox {
                background: #111827;
                color: #f9fafb;
                border: 1px solid #374151;
                border-radius: 8px;
                padding: 6px;
            }
            QProgressBar {
                background: #111827;
                color: #f9fafb;
                border: 1px solid #374151;
                border-radius: 8px;
